{
  "permissions": {
    "defaultMode": "plan"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "agent",
            "prompt": "Review the staged changes (run `git diff --staged`) for code quality, reuse opportunities, and efficiency issues. Apply minimal fixes if needed. Do NOT change test files or config files. Only fix issues in application code. Be concise — skip if changes look clean.",
            "timeout": 120,
            "statusMessage": "Running /simplify on staged changes..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/ridopark/src/roth-converter/.claude/hooks/post-commit-review.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash /home/ridopark/src/roth-converter/.claude/hooks/post-commit-harness-learn.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash /home/ridopark/src/roth-converter/.claude/hooks/post-commit-discord.sh",
            "timeout": 10000
          }
        ]
      }
    ]
  }
}
